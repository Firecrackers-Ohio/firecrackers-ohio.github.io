---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import CoachTitle from "../../components/teams/CoachTitle.astro";
import PlayerCard from "../../components/teams/PlayerCard.astro";

export async function getStaticPaths() {
  const teams = await getCollection("teams");
  return teams.map(team => ({
    params: { team: team.id },
    props: { team },
  }));
}

const { team } = Astro.props;

// Helper function to extract last name and get email from coach data
function getCoachEmail(
  coachName: string,
  coachEmail?: string
): { email: string; lastName: string } | null {
  if (!coachEmail) {
    return null;
  }

  // Extract the name part before the dash (e.g., "Phil Jones - Head Coach" -> "Phil Jones")
  const namePart = coachName.split(" - ")[0].trim();

  // Extract last name (assume it's the last word)
  const nameWords = namePart.split(" ");
  const lastName = nameWords[nameWords.length - 1];

  return { email: coachEmail, lastName };
}

const teamTitle = team.data.displayName || `${team.data.title} Team`;
const instagramUrl =
  team.data.instagramUrl || "https://www.instagram.com/firecrackers_oh/";
const facebookUrl =
  team.data.facebookUrl || "https://www.facebook.com/firecrackersohio";

const rosterImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/rosters/**/*.{jpg,jpeg,png,webp}",
  { eager: true }
);

function getPlayerImage(teamId: string, playerNumber: number): ImageMetadata | undefined {
  const extensions = ["jpg", "jpeg", "png", "webp"];
  for (const ext of extensions) {
    const path = `/src/assets/rosters/${teamId}/${playerNumber}.${ext}`;
    if (rosterImages[path]) return rosterImages[path].default;
  }
  return undefined;
}

function getTeamPhoto(teamId: string, filename: string): ImageMetadata | undefined {
  const path = `/src/assets/rosters/${teamId}/${filename}`;
  return rosterImages[path]?.default;
}

const teamPhoto = team.data.teamPhoto
  ? getTeamPhoto(team.id, team.data.teamPhoto)
  : undefined;
---

<Layout
  title={`${teamTitle} | Firecrackers Central Ohio`}
  description={`Meet the ${teamTitle} coaching staff and learn about their training philosophy, competitive structure, and player development approach.`}
>
  <div class="container mx-auto px-4 py-8">
    <CoachTitle teamName={team.data.title} instagramUrl={instagramUrl} facebookUrl={facebookUrl} />

    <div class="mx-auto max-w-4xl space-y-12">
      {teamPhoto && (
        <div class="hidden overflow-hidden rounded-lg md:block">
          <Image
            src={teamPhoto}
            alt={`${teamTitle} photo`}
            class="w-full object-cover"
            width={896}
          />
        </div>
      )}

      <!-- Section Navigation Tabs -->
      <div class="border-b border-gray-300 dark:border-gray-700">
        <nav
          class="-mb-px flex justify-between md:justify-start md:space-x-8"
          aria-label="Team sections"
        >
          <button
            data-section="roster"
            class="section-tab section-tab-active border-red text-red border-b-2 px-1 py-4 text-sm font-semibold transition-colors md:text-lg dark:text-red-400"
          >
            Roster
          </button>
          <button
            data-section="coaches"
            class="section-tab border-b-2 border-transparent px-1 py-4 text-sm font-semibold text-gray-600 transition-colors hover:border-gray-300 hover:text-gray-900 md:text-lg dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-gray-300"
          >
            Coaches
          </button>
          <button
            data-section="schedule"
            class="section-tab border-b-2 border-transparent px-1 py-4 text-sm font-semibold text-gray-600 transition-colors hover:border-gray-300 hover:text-gray-900 md:text-lg dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-gray-300"
          >
            Schedule
          </button>
          <button
            data-section="results"
            class="section-tab border-b-2 border-transparent px-1 py-4 text-sm font-semibold text-gray-600 transition-colors hover:border-gray-300 hover:text-gray-900 md:text-lg dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-gray-300"
          >
            Results
          </button>
        </nav>
      </div>

      <!-- Section Content -->
      <div class="section-content">
        <!-- Roster Section (default) -->
        <section id="roster-section" class="team-section">
          <h2 class="section-heading">ROSTER</h2>
          {
            team.data.roster && team.data.roster.length > 0 ? (
              <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
                {team.data.roster.map(player => (
                  <PlayerCard
                    name={player.name}
                    number={player.number}
                    position={player.position}
                    gradYear={player.gradYear}
                    highSchool={player.highSchool}
                    image={getPlayerImage(team.id, player.number)}
                  />
                ))}
              </div>
            ) : (
              <div class="card">
                <p class="body-text">Coming soon.</p>
              </div>
            )
          }
        </section>

        <!-- Coaches Section -->
        <section id="coaches-section" class="team-section hidden">
          <h2 class="section-heading">COACHING STAFF</h2>
          <div class="space-y-8">
            {
              team.data.staff.map(coach => {
                const coachEmailInfo = getCoachEmail(coach.name, coach.email);
                return (
                  <div class="card">
                    <div class="mb-4 flex items-center justify-between">
                      <h3 class="text-2xl font-semibold text-gray-900 dark:text-white">
                        {coach.name}
                      </h3>
                      {coachEmailInfo && (
                        <a
                          href={`mailto:${coachEmailInfo.email}`}
                          class="text-link text-sm font-medium dark:text-red-400"
                        >
                          Email Coach {coachEmailInfo.lastName}
                        </a>
                      )}
                    </div>
                    <div class="space-y-4">
                      {coach.bio.map(paragraph => (
                        <p class="body-text">{paragraph}</p>
                      ))}
                    </div>
                  </div>
                );
              })
            }
          </div>
        </section>

        <!-- Schedule Section -->
        <section id="schedule-section" class="team-section hidden">
          <h2 class="section-heading">2026 SPRING/SUMMER SCHEDULE</h2>
          {
            team.data.schedule && team.data.schedule.length > 0 ? (
              <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
                <table class="w-full text-left text-sm">
                  <thead>
                    <tr class="bg-red text-white">
                      <th class="px-4 py-3 font-semibold uppercase tracking-wide">Dates</th>
                      <th class="px-4 py-3 font-semibold uppercase tracking-wide">Tournament</th>
                      <th class="hidden px-4 py-3 font-semibold uppercase tracking-wide sm:table-cell">Location</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    {team.data.schedule.map((event, i) => (
                      <tr class={i % 2 === 0 ? "bg-white dark:bg-gray-900" : "bg-gray-50 dark:bg-gray-800/50"}>
                        <td class="whitespace-nowrap px-4 py-3 font-mono text-xs text-gray-600 dark:text-gray-400">{event.dates}</td>
                        <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">
                          {event.tournament}
                          <div class="mt-0.5 text-xs text-gray-500 sm:hidden dark:text-gray-400">{event.location}</div>
                        </td>
                        <td class="hidden px-4 py-3 text-gray-600 sm:table-cell dark:text-gray-400">{event.location}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="card">
                <p class="body-text">Coming soon.</p>
              </div>
            )
          }
        </section>

        <!-- Results Section -->
        <section id="results-section" class="team-section hidden">
          <h2 class="section-heading">RESULTS</h2>
          <div class="card">
            <p class="body-text">Coming soon.</p>
          </div>
        </section>
      </div>
    </div>

    <script>
      // Section navigation functionality
      const VALID_SECTIONS = ["roster", "coaches", "schedule", "results"];

      function activateSection(targetSection: string, updateHash = true) {
        const tabs = document.querySelectorAll(".section-tab");
        const sections = document.querySelectorAll(".team-section");

        // Update tab styles
        tabs.forEach(t => {
          t.classList.remove(
            "section-tab-active",
            "border-red",
            "text-red",
            "dark:text-red-400"
          );
          t.classList.add(
            "border-transparent",
            "text-gray-600",
            "dark:text-gray-400"
          );
        });

        const activeTab = document.querySelector(`[data-section="${targetSection}"]`);
        if (activeTab) {
          activeTab.classList.add(
            "section-tab-active",
            "border-red",
            "text-red",
            "dark:text-red-400"
          );
          activeTab.classList.remove(
            "border-transparent",
            "text-gray-600",
            "dark:text-gray-400"
          );
        }

        // Show/hide sections
        sections.forEach(section => {
          section.classList.add("hidden");
        });

        const activeSection = document.getElementById(`${targetSection}-section`);
        if (activeSection) {
          activeSection.classList.remove("hidden");
        }

        if (updateHash) {
          history.replaceState(null, "", `#${targetSection}`);
        }
      }

      document.addEventListener("DOMContentLoaded", () => {
        const tabs = document.querySelectorAll(".section-tab");

        tabs.forEach(tab => {
          tab.addEventListener("click", () => {
            const targetSection = tab.getAttribute("data-section");
            if (targetSection) activateSection(targetSection);
          });
        });

        // Activate section from URL hash on load
        const hash = window.location.hash.slice(1);
        if (hash && VALID_SECTIONS.includes(hash)) {
          activateSection(hash, false);
        }
      });

      // Handle browser back/forward navigation
      window.addEventListener("hashchange", () => {
        const hash = window.location.hash.slice(1);
        const section = VALID_SECTIONS.includes(hash) ? hash : "roster";
        activateSection(section, false);
      });
    </script>
  </div>
</Layout>
